---
import Base from '../layouts/Base.astro';
import { profile, socials, about, experience, skills, education } from '../data/resume';

const contactBits = [
  profile.email,
  profile.location,
  'strafer.dev',
  ...socials.filter((s) => s.label !== 'X').map((s) => `${s.label}: ${s.handle}`),
];
---

<Base title={`${profile.name} — CV`} noindex={true}>
  <button id="print-btn" class="print-btn no-print" type="button">⌘P · Save as PDF</button>

  <article class="cv">
    <header class="cv-head">
      <h1>{profile.name}</h1>
      <p class="cv-role">{profile.role}</p>
      <p class="cv-contact">{contactBits.join('  ·  ')}</p>
    </header>

    <section class="cv-section">
      <h2>Summary</h2>
      <p class="cv-summary">{about.join(' ')}</p>
    </section>

    <section class="cv-section">
      <h2>Experience</h2>
      {experience.map((r) => (
        <div class="cv-role-block">
          <div class="cv-role-row">
            <span class="cv-role-title"><strong>{r.role}</strong>, {r.org}</span>
            <time>{r.period}</time>
          </div>
          {r.progression && <p class="cv-progression">{r.progression.join('  →  ')}</p>}
          <ul>
            {r.highlights.map((h) => <li>{h}</li>)}
          </ul>
        </div>
      ))}
    </section>

    <section class="cv-section">
      <h2>Skills</h2>
      <dl class="cv-skills">
        {skills.map((g) => (
          <div class="cv-skill-row">
            <dt>{g.title}</dt>
            <dd>{g.items.join(' · ')}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="cv-section">
      <h2>Education</h2>
      {education.map((e) => (
        <div class="cv-role-row">
          <span><strong>{e.qualification}</strong>, {e.org}</span>
          <time>{e.period}</time>
        </div>
      ))}
    </section>
  </article>
</Base>

<script>
  document.getElementById('print-btn')?.addEventListener('click', () => window.print());
</script>

<style>
  .cv {
    max-width: 820px;
    margin: 2.5rem auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .cv-head { border-bottom: var(--rule-ink); padding-bottom: 0.85rem; margin-bottom: 1.4rem; }
  .cv-head h1 { font-family: var(--display); font-weight: 800; font-size: 2rem; margin: 0; letter-spacing: -0.02em; }
  .cv-role { font-weight: 600; margin: 0.2rem 0 0.5rem; }
  .cv-contact { font-family: var(--mono); font-size: 0.72rem; color: var(--gray); margin: 0; }

  .cv-section { margin-bottom: 1.5rem; }
  .cv-section h2 {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--signal);
    border-bottom: var(--rule);
    padding-bottom: 0.35rem;
    margin: 0 0 0.85rem;
  }
  .cv-summary { margin: 0; max-width: 75ch; }

  .cv-role-block { margin-bottom: 1.1rem; break-inside: avoid; }
  .cv-role-row { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; }
  .cv-role-row time { font-family: var(--mono); font-variant-numeric: tabular-nums; font-size: 0.74rem; color: var(--gray); white-space: nowrap; }
  .cv-role-title { font-size: 1rem; }
  .cv-progression { font-family: var(--mono); font-size: 0.72rem; color: var(--gray); margin: 0.2rem 0 0.4rem; }
  .cv-role-block ul { margin: 0.35rem 0 0; padding-left: 1.1rem; }
  .cv-role-block li { margin-bottom: 0.3rem; }

  .cv-skills { margin: 0; }
  .cv-skill-row { display: grid; grid-template-columns: 14rem 1fr; gap: 0.75rem; padding: 0.3rem 0; border-top: var(--rule); }
  .cv-skill-row:first-child { border-top: 0; }
  .cv-skill-row dt { font-weight: 600; }
  .cv-skill-row dd { margin: 0; color: var(--ink-soft); }

  .print-btn {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    font-family: var(--mono);
    font-size: 0.74rem;
    padding: 0.55rem 0.9rem;
    background: var(--ink);
    color: var(--paper);
    border: var(--rule-ink);
    cursor: pointer;
  }
  .print-btn:hover { background: var(--signal); border-color: var(--signal); }

  @media (max-width: 560px) {
    .cv-skill-row { grid-template-columns: 1fr; gap: 0.1rem; }
  }

  @media print {
    :global(html) { font-size: 10.5pt; }
    .no-print { display: none !important; }
    .cv { margin: 0; max-width: none; padding: 0; }
    .cv-section { margin-bottom: 0.9rem; }
    .cv-role-block { margin-bottom: 0.8rem; }
    a { color: inherit; text-decoration: none; }
  }

  @page { size: A4; margin: 14mm; }
</style>
